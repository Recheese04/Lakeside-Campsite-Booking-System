// Prisma Schema — Lakeside Campsite Booking System
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================
// AUTH & USERS
// ====================================

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  firstName   String
  lastName    String
  phone       String?
  avatarUrl   String?
  role        Role      @default(CUSTOMER)
  isVerified  Boolean   @default(false)
  isBanned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  bookings    Booking[]
  reviews     Review[]
  mealOrders  MealOrder[]

  @@map("users")
}

// ====================================
// CAMPSITES
// ====================================

enum CampsiteStatus {
  AVAILABLE
  MAINTENANCE
  CLOSED
}

model Campsite {
  id            String          @id @default(cuid())
  name          String
  description   String
  pricePerNight Decimal         @db.Decimal(10, 2)
  capacity      Int
  location      String?
  status        CampsiteStatus  @default(AVAILABLE)
  amenities     String[]        // e.g. ["wifi", "bonfire_pit", "restroom"]
  images        String[]        // URLs from Supabase Storage
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  bookings      Booking[]
  reviews       Review[]

  @@map("campsites")
}

// ====================================
// BOOKINGS
// ====================================

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  campsiteId    String
  checkIn       DateTime
  checkOut      DateTime
  guestCount    Int
  totalPrice    Decimal       @db.Decimal(10, 2)
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  specialNotes  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campsite      Campsite      @relation(fields: [campsiteId], references: [id])
  equipments    BookingEquipment[]
  payment       Payment?

  @@map("bookings")
}

// ====================================
// EQUIPMENT / RENTALS
// ====================================

model Equipment {
  id          String    @id @default(cuid())
  name        String
  description String?
  pricePerDay Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0)
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  bookings    BookingEquipment[]

  @@map("equipment")
}

model BookingEquipment {
  id          String    @id @default(cuid())
  bookingId   String
  equipmentId String
  quantity    Int       @default(1)

  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  @@unique([bookingId, equipmentId])
  @@map("booking_equipment")
}

// ====================================
// PAYMENTS
// ====================================

model Payment {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  amount          Decimal   @db.Decimal(10, 2)
  method          String    // e.g. "gcash", "card", "cash"
  referenceNumber String?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ====================================
// REVIEWS
// ====================================

model Review {
  id            String    @id @default(cuid())
  userId        String
  campsiteId    String
  rating        Int       // 1–5
  comment       String?
  adminResponse String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campsite    Campsite  @relation(fields: [campsiteId], references: [id])

  @@unique([userId, campsiteId])  // One review per user per campsite
  @@map("reviews")
}

// ====================================
// NOTIFICATIONS
// ====================================

model Notification {
  id          String    @id @default(cuid())
  title       String
  message     String
  type        String    @default("General") // General, Payment, Booking, Meal, System
  recipientId String?   // null = broadcast to all users
  sentById    String?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("notifications")
}

// ====================================
// MEALS / RESTAURANT
// ====================================

enum MealCategory {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  DRINK
}

model MealItem {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Decimal      @db.Decimal(10, 2)
  category    MealCategory @default(LUNCH)
  imageUrl    String?
  available   Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("meal_items")
}

enum MealOrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model MealOrder {
  id           String          @id @default(cuid())
  userId       String
  items        Json            // [{mealItemId, name, quantity, price}]
  totalPrice   Decimal         @db.Decimal(10, 2)
  status       MealOrderStatus @default(PENDING)
  deliveryTime DateTime?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meal_orders")
}

// ====================================
// ACTIVITIES
// ====================================

model Activity {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  capacity    Int       @default(10)
  schedule    String?   // e.g. "Daily 8AM-5PM"
  available   Boolean   @default(true)
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("activities")
}
